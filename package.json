{
  "name": "@dotbrains/sluice",
  "version": "0.1.0",
  "description": "Batched PostgreSQL backfill runner with cycle detection, resume, and migration interleaving",
  "license": "MIT",
  "author": "dotbrains",
  "repository": {
    "type": "git",
    "url": "https://github.com/dotbrains/sluice.git"
  },
  "keywords": [
    "postgresql",
    "postgres",
    "backfill",
    "migration",
    "batch",
    "postgrator",
    "database"
  ],
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sluice": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:db": "vitest run --config vitest.config.db.ts",
    "test:all": "npm run test:unit && npm run test:db",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "fast-glob": "^3.3.3",
    "postgrator": "^7.3.0"
  },
  "peerDependencies": {
    "pg-promise": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "pg-promise": {
      "optional": false
    }
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.13.0",
    "@types/node": "^22.0.0",
    "pg": "^8.13.0",
    "pg-promise": "^11.10.2",
    "testcontainers": "^11.13.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
